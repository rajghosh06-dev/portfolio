# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
.turbo/

# GitHub Pages deployment output is generated in CI/local builds
# and uploaded by Actions. It should not be committed.
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
.idea/
.vscode/
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local/reference archives not needed for the live site
/.tmp-old-portfolio/
/.tmp-reference-navbar/
/.qa-shots/
/.edge-cdp-profile/
/.edge-profile/
/.chrome-profile/
/.tmp-dev.log
/.tmp-dev.err

# typescript
*.tsbuildinfo
next-env.d.ts
